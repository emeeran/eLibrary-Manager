# Database
DATABASE_URL=sqlite+aiosqlite:///./dawnstar_data/dawnstar.db

# Library
LIBRARY_PATH=./library
COVERS_PATH=./static_covers

# AI Providers (in priority order)
# Google Gemini (Primary)
GOOGLE_API_KEY=your_google_key_here
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_RATE_LIMIT_RPM=15

# Groq (Secondary)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_RATE_LIMIT_RPM=30

# Ollama Cloud (Tertiary)
OLLAMA_CLOUD_URL=https://api.ollama.ai
OLLAMA_CLOUD_MODEL=llama3.3

# Ollama Local (Fallback - works offline)
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_LOCAL_MODEL=llama3.3

# AI Settings
AI_DEFAULT_PROVIDER=auto  # auto, google, groq, ollama_cloud, ollama_local
AI_ENABLE_FALLBACK=true

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Performance
MAX_COVER_SIZE=300000
LAZY_LOAD_BATCH_SIZE=20
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
